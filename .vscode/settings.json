{
    "python.analysis.exclude": [
        "**/.venv",
        "**/__pycache__"
    ],
    "python.analysis.ignore": [
        "**/.venv",
        "**/__pycache__"
    ],
    "python.linting.ignorePatterns": [
        "**/.venv/**/*.py",
        "**/__pycache__/**/*.py"
    ],
    "files.watcherExclude": {
        "**/.venv/**": true,
        "**/__pycache__/**": true
    }
}
